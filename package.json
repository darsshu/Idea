    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongoose": "^9.3.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "puppeteer-core": "^24.39.1"
  }
}
