{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/server.js"
    },
    {
      "source": "/(.*).(js|css|png|jpg|svg|ico)",
      "destination": "/client/dist/$1.$2"
    },
    {
      "source": "/(.*)",
      "destination": "/client/dist/index.html"
    }
  ],
  "functions": {
    "server/server.js": {
      "runtime": "vercel-node@latest",
      "includeFiles": "server/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "*/5 * * * *"
    }
  ]
}
